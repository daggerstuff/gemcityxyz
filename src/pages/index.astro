---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE, SOCIAL_LINKS } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

// Error handling for fetching recent posts
let latestPosts: Awaited<ReturnType<typeof getRecentPosts>> = []
try {
  latestPosts = await getRecentPosts(2)
} catch (error) {
  console.error('Error fetching recent posts:', error)
}

// Person Schema for homepage SEO
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.href,
  description: SITE.description,
}

// Organization Schema
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.title,
  url: SITE.href,
  description: SITE.description,
}

// Website Schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: SITE.href,
  description: SITE.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.href}/blog?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

const emailLink =
  SOCIAL_LINKS.find((link) => link.href.startsWith('mailto:')) ||
  SOCIAL_LINKS.find((link) => link.label.toLowerCase() === 'email')
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title={SITE.title} fullTitle={true} />

  <!-- Schema Markup for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
  />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero Section -->
  <section
    class="relative overflow-hidden rounded-xl border"
    style="min-height: clamp(260px, 34vh, 340px);"
  >
    <!-- Gradient Background -->
    <div
      class="from-primary/5 via-background to-background absolute inset-0 bg-gradient-to-br"
      aria-hidden="true"
    >
    </div>

    <!-- Content -->
    <div class="relative z-10 p-8 md:p-12">
      <div class="flex flex-col gap-8">
        <!-- Main Content -->
        <div class="min-w-0 flex-1 space-y-6">
          <!-- Heading -->
          <div class="space-y-4">
            <h1
              class="text-4xl leading-[1.1] font-bold tracking-tight sm:text-5xl md:text-6xl"
              style="font-variation-settings: 'wght' 700;"
            >
              Welcome to<br class="hidden sm:block" />
              <span class="text-primary">{SITE.title}</span>
            </h1>
            <p
              class="text-muted-foreground mt-4 max-w-xl text-base leading-relaxed md:text-lg"
              style="min-height: 3rem;"
            >
              {SITE.description}
            </p>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap items-center gap-3">
            <Link
              href="/blog"
              class={buttonVariants({ variant: 'default', size: 'lg' })}
            >
              Read the blog
              <Icon name="lucide:arrow-right" class="size-4" />
            </Link>
            <Link
              href="/about"
              class={buttonVariants({ variant: 'ghost', size: 'lg' })}
            >
              Explore my work
            </Link>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest from the blog -->
  {
    latestPosts && latestPosts.length > 0 && (
      <section class="mt-10">
        <div class="mb-4 flex items-center justify-between">
          <div>
            <h2 class="text-2xl font-semibold">Latest writing</h2>
          </div>
          <Link
            href="/blog"
            class="text-primary hover:text-primary/80 inline-flex min-h-11 items-center gap-1.5 px-2 text-sm font-medium transition-colors"
          >
            View all
            <Icon name="lucide:arrow-right" class="size-4" />
          </Link>
        </div>

        <div class="space-y-2">
          {latestPosts.map((post) => (
            <article>
              <BlogCard entry={post} />
            </article>
          ))}
        </div>
      </section>
    )
  }

  <!-- Compact Contact CTA -->
  <section class="mt-10">
    <div
      class="border-border/60 flex flex-wrap items-center justify-between gap-3 border-t pt-6"
    >
      <p class="text-muted-foreground text-sm">
        Open to collaborations and experiments.
      </p>
      {
        emailLink && (
          <Link
            href={emailLink.href}
            class={
              buttonVariants({ variant: 'ghost' }) +
              ' inline-flex items-center gap-2'
            }
          >
            <Icon name="lucide:mail" class="size-4" />
            Contact me
          </Link>
        )
      }
    </div>
  </section>
</Layout>
