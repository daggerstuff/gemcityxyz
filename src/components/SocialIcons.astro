---
import Link from '@/components/Link.astro'
import { buttonVariants } from '@/components/ui/button'
import { ICON_MAP } from '@/consts'
import type { SocialLink } from '@/types'
import {
  Github,
  Twitter,
  Mail,
  Rss,
  Globe,
  Linkedin,
  type LucideIcon,
} from 'lucide-react'

interface Props {
  links: SocialLink[]
}

const { links } = Astro.props as Props

const ICON_COMPONENTS: Record<string, LucideIcon> = {
  'lucide:globe': Globe,
  'lucide:github': Github,
  'lucide:linkedin': Linkedin,
  'lucide:twitter': Twitter,
  'lucide:mail': Mail,
  'lucide:rss': Rss,
}
---

<ul class="flex flex-wrap gap-2" role="list">
  {links.map(({ href, label }) => {
    const IconComponent = ICON_COMPONENTS[ICON_MAP[label as keyof typeof ICON_MAP]] || Globe
    return (
      <li>
        <Link
          href={href}
          aria-label={label}
          title={label}
          class={buttonVariants({ variant: 'outline', size: 'icon' })}
          external
        >
          <IconComponent className="size-4" />
        </Link>
      </li>
    )
  })}
</ul>
