---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import Link from "@/components/Link.astro";
import { badgeVariants } from "@/components/ui/badge";
import { SITE } from "@/consts";
import { getRelatedPosts } from "@/lib/data-utils";
import { formatDate, getTagVariant } from "@/lib/utils";

interface Props {
	currentPostId: string;
	count?: number;
}

const { currentPostId, count = 3 } = Astro.props;

// Get related posts based on shared tags
let relatedPosts: CollectionEntry<"blog">[] = [];
try {
	relatedPosts = await getRelatedPosts(currentPostId, count);
} catch (error) {
	console.error("Error fetching related posts:", error);
}
---

{
  relatedPosts.length > 0 && (
    <section class="mt-12">
      <div class="mb-6">
        <h2 class="mb-2 text-2xl font-semibold">Related Posts</h2>
        <p class="text-muted-foreground text-sm">
          Further reading on similar topics
        </p>
      </div>

      <div class="grid gap-4">
        {relatedPosts.map((post) => (
          <Link
            href={`/blog/${post.id}`}
            class="group border-border/50 bg-muted/20 hover:bg-muted/40 hover:border-primary/30 block rounded-lg border p-4 transition-all duration-200"
          >
            <article class="flex flex-col gap-3">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <h3 class="text-foreground group-hover:text-primary mb-1 text-lg font-semibold transition-colors">
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="text-muted-foreground line-clamp-2 text-sm">
                      {post.data.description}
                    </p>
                  )}
                </div>
                <Icon
                  name="lucide:arrow-right"
                  class="text-primary/70 group-hover:text-primary mt-1 size-5 shrink-0 transition-all group-hover:translate-x-1"
                  aria-hidden="true"
                />
              </div>

              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs">
                <div class="text-muted-foreground flex items-center gap-1.5">
                  <Icon name="lucide:calendar" class="size-3.5" />
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                </div>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag: string) => {
                      const { variant, className } = getTagVariant(tag)
                      return (
                        <span
                          class={`${badgeVariants({ variant })} ${className || ''} text-[10px] px-1.5 py-0.5`}
                        >
                          <Icon name="lucide:hash" class="size-2.5" />
                          {tag}
                        </span>
                      )
                    })}
                    {post.data.tags.length > 3 && (
                      <span class="text-muted-foreground text-[10px]">
                        +{post.data.tags.length - 3} more
                      </span>
                    )}
                  </div>
                )}
              </div>
            </article>
          </Link>
        ))}
      </div>

      <div class="mt-6">
        <Link
          href="/blog"
          class="text-muted-foreground hover:text-primary inline-flex items-center gap-1.5 text-sm transition-colors"
        >
          <Icon name="lucide:library" class="size-4" />
          View all posts
          <Icon name="lucide:arrow-right" class="size-4" />
        </Link>
      </div>
    </section>
  )
}
